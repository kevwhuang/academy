{
    "env": {
        "browser": true,
        "commonjs": true,
        "es2021": true,
        "node": true
    },
    "extends": "airbnb-base",
    "overrides": [],
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "plugins": [
        "chai",
        "mocha"
    ],
    "rules": {
        "indent": "off",
        "no-console": "off",
        "no-unused-vars": "warn"
    }
}